flowchart TB
  subgraph Public Layer
    User[User]
    ALB[Application Load Balancer]
  end
  subgraph Kubernetes Layer
    EKS[EKS Cluster]
    NodeGroupX86[x86 Node Group (x86/amd64)]
    NodeGroupARM[Graviton Node Group (arm64)]
    Karpenter[Karpenter Autoscaler]
  end
  subgraph Data Layer
    RDS[(RDS PostgreSQL)]
    S3[S3 Bucket]
    ECR[ECR Registry]
    Secrets[Secrets Manager]
  end
  subgraph CI/CD & Observability
    CI[CI/CD Pipeline]
    Datadog[Datadog]
  end

  User --> ALB
  ALB --> EKS
  EKS --> NodeGroupX86
  EKS --> NodeGroupARM
  NodeGroupX86 -.-> Karpenter
  NodeGroupARM -.-> Karpenter
  EKS --> RDS
  EKS --> S3
  EKS --> ECR
  EKS --> Secrets
  CI --> ECR
  CI --> EKS
  RDS -->|Backups| S3
  EKS --> Datadog
  NodeGroupX86 --> Datadog
  NodeGroupARM --> Datadog
